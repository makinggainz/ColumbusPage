# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real keys.

# Google Gemini API key for the Columbus support chat AI (app/api/columbus-chat).
# Get a free key at https://aistudio.google.com/apikey
# Without this, typed questions fall back to keyword matching + contact form.
GEMINI_API_KEY=

# Optional: override the default model (gemini-2.5-flash).
# Check ai.google.dev/gemini-api/docs/models for available model IDs.
# GEMINI_MODEL=

# HubSpot Forms API — wires contact form submissions to your CRM (app/api/contact).
# Portal ID: HubSpot → Settings → Account Setup → Account Defaults.
# Form GUID: HubSpot → Marketing → Forms → (select form) → Share → Embed code (the UUID).
# NOTE: The form must exist in HubSpot with these fields mapped as contact properties:
#   email, firstname, lastname, message, industry, numemployees, jobtitle,
#   how_did_you_hear_about_us (create as a custom property if missing).
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=
