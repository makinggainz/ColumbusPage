# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real keys.

# Groq API key for the Columbus support chat AI (app/api/columbus-chat).
# Get a free key at https://console.groq.com/keys
# Without this, typed questions fall back to keyword matching + contact form.
GROQ_API_KEY=

# Optional: override the default model (llama-3.1-8b-instant).
# Set to llama-3.3-70b-versatile on a paid Groq tier for stronger adherence.
# GROQ_MODEL=
