# PostHog analytics
# US region (default). For EU: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_REPLACE_ME
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Mapbox (consumer map)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.REPLACE_ME

# Gemini (AI chat)
GEMINI_API_KEY=REPLACE_ME
GEMINI_MODEL=gemini-2.0-flash

# HubSpot (contact form)
HUBSPOT_PORTAL_ID=REPLACE_ME
HUBSPOT_FORM_GUID=REPLACE_ME
